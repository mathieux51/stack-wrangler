{
  "name": "stack-wrangler",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"bun run dev:frontend\" \"bun run dev:backend\" \"bun run dev:ai\"",
    "dev:frontend": "cd frontend && bun run dev",
    "dev:backend": "cd backend && cargo watch -x run",
    "dev:ai": "cd ai-model && source .venv/bin/activate && python app.py",
    "build": "bun run build:frontend && bun run build:backend",
    "build:frontend": "cd frontend && bun run build",
    "build:backend": "cd backend && cargo build --release",
    "docker:build": "docker-compose build",
    "docker:up": "docker-compose up",
    "docker:down": "docker-compose down"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}